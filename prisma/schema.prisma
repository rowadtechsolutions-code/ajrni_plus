generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  OFFICE
  ADMIN
}

enum OfficeStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum BookingStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
  COMPLETED
}

enum CarStatus {
  AVAILABLE
  BOOKED
  MAINTENANCE
  UNAVAILABLE
}

enum Transmission {
  AUTOMATIC
  MANUAL
}

enum FuelType {
  GASOLINE
  DIESEL
  ELECTRIC
  HYBRID
}

model User {
  id            String   @id @default(cuid())
  name          String?
  email         String   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  phone         String?
  whatsapp      String?
  role          Role     @default(CUSTOMER)
  locale        String   @default("ar")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  office        Office?
  accounts      Account[]
  sessions      Session[]
  bookings      Booking[]
  reviews       Review[]
  wishlist      WishlistItem[]
  recentlyViewed RecentlyViewed[]
  messages      Message[]
  notifications Notification[]

  @@map("users")
}

model Office {
  id            String       @id @default(cuid())
  nameAr        String
  nameEn        String
  slug          String       @unique
  email         String       @unique
  phone         String
  whatsapp      String?
  status        OfficeStatus @default(PENDING)
  logo          String?
  coverImage    String?
  descriptionAr String?
  descriptionEn String?
  licenseDoc    String?
  country       String
  city          String
  address       String?
  lat           Float?
  lng           Float?
  verified      Boolean      @default(false)
  featured      Boolean      @default(false)
  responseRate  Int          @default(0)
  responseTime  Int          @default(0)
  totalCars     Int          @default(0)
  totalBookings Int          @default(0)
  rating        Float        @default(0.0)
  views         Int          @default(0)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  userId        String       @unique
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  cars          Car[]
  bookings      Booking[]
  reviews       Review[]
  messages      Message[]

  @@map("offices")
}

model Car {
  id            String       @id @default(cuid())
  titleAr       String
  titleEn       String
  slug          String       @unique
  brand         String
  model         String
  year          Int
  pricePerDay   Float
  currency      String       @default("SAR")
  seats         Int
  transmission  Transmission @default(AUTOMATIC)
  fuelType      FuelType     @default(GASOLINE)
  fuelCapacity  String?
  mileage       String?
  color         String?
  descriptionAr String?
  descriptionEn String?
  images        String[]
  plateNumber   String?
  status        CarStatus    @default(AVAILABLE)
  featured      Boolean      @default(false)
  availableNow  Boolean      @default(false)
  airportDelivery Boolean    @default(false)
  withDriver     Boolean     @default(false)
  insurance      Boolean     @default(true)
  unlimitedMileage Boolean   @default(false)
  airConditioning Boolean    @default(true)
  gps            Boolean     @default(false)
  bluetooth      Boolean     @default(false)
  usbPort        Boolean     @default(true)
  views          Int         @default(0)
  country        String
  city           String
  pickupLocation String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  officeId      String
  office        Office       @relation(fields: [officeId], references: [id], onDelete: Cascade)
  bookings      Booking[]
  reviews       Review[]
  wishlistItems WishlistItem[]
  recentlyViewed RecentlyViewed[]
  availability  Availability[]

  @@map("cars")
}

model Booking {
  id              String        @id @default(cuid())
  customerName    String
  customerPhone   String
  customerWhatsapp String?
  pickupLocation  String?
  startDate       DateTime
  endDate         DateTime
  message         String?
  status          BookingStatus @default(PENDING)
  totalAmount     Float?
  officeNotes     String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  carId           String
  car             Car           @relation(fields: [carId], references: [id], onDelete: Cascade)
  customerId      String
  customer        User          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  officeId        String
  office          Office        @relation(fields: [officeId], references: [id], onDelete: Cascade)
  messages        Message[]

  @@map("bookings")
}

model Message {
  id        String   @id @default(cuid())
  content   String
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id])
  bookingId String
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  officeId  String
  office    Office   @relation(fields: [officeId], references: [id])
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("messages")
}

model Review {
  id        String   @id @default(cuid())
  rating    Int
  comment   String?
  carId     String
  car       Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  officeId  String
  office    Office   @relation(fields: [officeId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@map("reviews")
}

model WishlistItem {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  carId  String
  car    Car    @relation(fields: [carId], references: [id], onDelete: Cascade)

  @@unique([userId, carId])
  @@map("wishlist_items")
}

model RecentlyViewed {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  carId     String
  car       Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  viewedAt  DateTime @default(now())

  @@map("recently_viewed")
}

model Availability {
  id       String   @id @default(cuid())
  carId    String
  car      Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  date     DateTime
  available Boolean @default(true)

  @@unique([carId, date])
  @@map("availability")
}

model City {
  id      String  @id @default(cuid())
  nameAr  String
  nameEn  String
  country String
  active  Boolean @default(true)

  @@map("cities")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String
  type      String
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  @@map("notifications")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model CmsPage {
  id      String @id @default(cuid())
  slug    String @unique
  titleAr String
  titleEn String
  bodyAr  String
  bodyEn  String
  active  Boolean @default(true)

  @@map("cms_pages")
}
